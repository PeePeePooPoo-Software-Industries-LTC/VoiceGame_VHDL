0028fc64 <_exit>:
 *
 * ALT_EXIT is mapped onto the _exit() system call in alt_syscall.h
 */

void ALT_EXIT (int exit_code)
{
  28fc64:	defffd04 	addi	sp,sp,-12
  28fc68:	df000215 	stw	fp,8(sp)
  28fc6c:	df000204 	addi	fp,sp,8
